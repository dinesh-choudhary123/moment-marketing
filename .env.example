# ─── YouTube Data API v3 ───────────────────────────────────────────────────────
# Create keys at https://console.cloud.google.com → APIs & Services → YouTube Data API v3
# Each key has 10,000 quota units/day. Trending fetch = 1 unit. Search = 100 units.
# Add up to 3 keys — they rotate automatically when one hits quota.
YOUTUBE_API_KEY=your_youtube_api_key_1
YOUTUBE_API_KEY_2=your_youtube_api_key_2
YOUTUBE_API_KEY_3=your_youtube_api_key_3

# ─── Apify Token ──────────────────────────────────────────────────────────────
# Required for Instagram hashtag scraping and Twitter/X trending.
# Get token at https://console.apify.com/account/integrations
# Recommended budget: $3–5/day. Current actors used:
#   - apify/instagram-hashtag-scraper (Instagram)
#   - quacker/twitter-scraper         (Twitter/X)
APIFY_TOKEN=your_apify_api_token
